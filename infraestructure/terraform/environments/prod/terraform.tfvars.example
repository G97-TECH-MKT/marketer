# ─── Copy this file to terraform.tfvars and fill in your values ──────────────
# NEVER commit terraform.tfvars (it contains secrets)

aws_region = "us-east-1"

# ─── Existing Network ─────────────────────────────────────────────────────────
vpc_id             = "vpc-xxxxxxxxxxxxxxxxx"
vpc_cidr           = "10.0.0.0/16"
public_subnet_ids  = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]
private_subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]

# ─── TLS ─────────────────────────────────────────────────────────────────────
certificate_arn   = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
alb_internal      = true
alb_allowed_cidrs = ["10.0.0.0/8"]

# ─── IAM ─────────────────────────────────────────────────────────────────────
permission_boundary_arn = "arn:aws:iam::ACCOUNT_ID:policy/MarketerPermissionBoundary"

# ─── Container Image ──────────────────────────────────────────────────────────
image_tag = "latest"   # overridden by CI/CD with git SHA

# ─── Secrets (use environment variables instead: TF_VAR_gemini_api_key etc.) ──
gemini_api_key        = "REPLACE_ME"
inbound_token         = "REPLACE_ME"
orch_callback_api_key = "REPLACE_ME"

# ─── App Config ───────────────────────────────────────────────────────────────
gemini_model            = "gemini-2.5-flash-preview"
task_cpu                = 256
task_memory             = 512
min_capacity            = 2
max_capacity            = 10
llm_timeout             = 30
callback_retry_attempts = 2
log_retention_days      = 90
alert_email             = "alerts@orbidi.com"
