# ─── Gemini LLM ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=replace-with-your-key
GEMINI_MODEL=gemini-3-flash-preview
LLM_TIMEOUT_SECONDS=60

# ─── Logging / prompt tuning ─────────────────────────────────────────────────
LOG_LEVEL=INFO
EXTRAS_LIST_TRUNCATION=10
LLM_MAX_OUTPUT_TOKENS=16384
PROMPT_TEXT_TRUNCATION_CHARS=600

# ─── ROUTER integration ──────────────────────────────────────────────────────
# Inbound: Authorization: Bearer <INBOUND_TOKEN> esperado en POST /tasks.
# Mismo valor se registra en agents.auth_token del router. Vacío desactiva check (dev only).
INBOUND_TOKEN=

# Outbound: X-API-Key que marketer pone en PATCH al callback_url.
# Lo asigna el router team durante el registro del agente.
ORCH_CALLBACK_API_KEY=

# Callback HTTP settings
CALLBACK_HTTP_TIMEOUT_SECONDS=30
CALLBACK_RETRY_ATTEMPTS=2

# Orchestrator job-creation API. subscription_strategy fan-out POSTea
# CreateJobRequest a {ORCH_API_BASE_URL}/api/v1/jobs por cada sub-job
# job-router después del PATCH final. Vacío → sub-jobs quedan sin dispatch
# al orquestador (marketer.jobs.dispatch_status='failed').
ORCH_API_BASE_URL=
ORCH_API_HTTP_TIMEOUT_SECONDS=15

# ─── Persistence (PostgreSQL) ────────────────────────────────────────────────
# Vacío → marketer arranca en "degraded mode": actions hardcoded fallback, sin
# runs persistidos, sin memory por cliente. Solo para dev local sin DB.
# Producción DEBE proveer este valor.
DATABASE_URL=
# Ejemplo: postgresql+asyncpg://marketer:password@localhost:5432/marketer

DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=10

# ─── Docker compose Postgres (only for `docker compose up -d postgres`) ──────
# Consumed by docker-compose.yml when provisioning the dev Postgres container.
# Defaults match the historical dev setup (read by compose via ${VAR:-default}).
# Change POSTGRES_PASSWORD to anything non-trivial if the container is reachable
# beyond localhost.
POSTGRES_USER=marketer
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=marketer
POSTGRES_HOST_PORT=5433

# Retención de rows en marketer_runs (días). 0 = sin límite.
RUNS_RETENTION_DAYS=90

# TTL de marketer_client_memory (días). 0 = no expira.
CLIENT_MEMORY_TTL_DAYS=0

# Cache in-memory del registry de actions (segundos).
ACTIONS_CACHE_TTL_SECONDS=60
